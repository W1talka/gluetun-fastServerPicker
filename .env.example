DOCKER_HOST=unix:///var/run/docker.sock
PUID=1000
PGID=1000
# Docker socket GID — find yours with: stat -c '%g' /var/run/docker.sock
DOCKER_GID=985

PICKER_GLUETUN_BASE_URL=http://your-gluetun-host:8000
PICKER_GLUETUN_USERNAME=
PICKER_GLUETUN_PASSWORD=
PICKER_GLUETUN_HEADERS=x-api-key=your-gluetun-api-key

OPENVPN_USER=your-privado-username
OPENVPN_PASSWORD=your-privado-password

PICKER_CANDIDATE_HOSTNAMES=
PICKER_REGION=north_america
PICKER_CANDIDATE_RANDOM=true
PICKER_BENCHMARK_URLS=http://speedtest.newark.linode.com/100MB-newark.bin
PICKER_BENCHMARK_DURATION_SECONDS=8
PICKER_BENCHMARK_CONNECT_TIMEOUT_SECONDS=45
PICKER_BENCHMARK_INTERVAL_SECONDS=21600
PICKER_BENCHMARK_SWITCH_THRESHOLD=1.10
PICKER_OPENVPN_VERBOSITY=3
PICKER_STATE_FILEPATH=/data/state.json
PICKER_CATALOG_FILEPATH=/data/servers.json
PICKER_CATALOG_MAX_AGE_SECONDS=604800

# Optional: Telegram notifications after each benchmark
PICKER_TELEGRAM_BOT_TOKEN=
PICKER_TELEGRAM_CHAT_ID=

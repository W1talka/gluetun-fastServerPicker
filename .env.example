DOCKER_HOST=unix:///var/run/docker.sock

PICKER_GLUETUN_BASE_URL=http://your-gluetun-host:8000
PICKER_GLUETUN_USERNAME=
PICKER_GLUETUN_PASSWORD=

OPENVPN_USER=your-privado-username
OPENVPN_PASSWORD=your-privado-password

PICKER_CANDIDATE_HOSTNAMES=
PICKER_REGION=north_america
PICKER_BENCHMARK_URLS=https://proof.ovh.net/files/100Mb.dat
PICKER_BENCHMARK_DURATION_SECONDS=8
PICKER_BENCHMARK_CONNECT_TIMEOUT_SECONDS=45
PICKER_BENCHMARK_INTERVAL_SECONDS=21600
PICKER_BENCHMARK_SWITCH_THRESHOLD=1.10
PICKER_OPENVPN_VERBOSITY=3
PICKER_STATE_FILEPATH=/state/state.json
PICKER_CATALOG_FILEPATH=/state/servers.json
PICKER_CATALOG_MAX_AGE_SECONDS=604800
